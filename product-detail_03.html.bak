  font-size: 15px;
  font-weight: 500;
  padding: 12px 18px;
  color: #333;
  transition: all 0.3s ease;
}

.navbar-nav > li > a:hover,
.navbar-nav > li.active > a {
  color: #0072ce;
}

/* Dropdown menu */
.dropdown-menu {
  min-width: 220px;
  padding: 8px 0;
  border-radius: 0;
  border: 1px solid #eaeaea;
}

.dropdown-menu > li > a {
  padding: 10px 18px;
  font-size: 14px;
  color: #444;
}

.dropdown-menu > li > a:hover {
  background: #f5f5f5;
  color: #0072ce;
}
</style>

  <!-- ====== HERO SECTION ====== -->
  <section style="background:#f5f5f5; padding:100px 0; margin-top:60px; text-align:center;">
    <div class="container">
      <h1 style="font-size:36px; font-weight:700;">Precision Depth Gauge</h1>
      <p style="font-size:18px; color:#555;">Professional Measurement Tool with ±0.05mm Accuracy for Depth & Cavity Measurement</p>
      <img src="images/product-3.jpg" alt="Depth Gauge" class="img-responsive center-block" style="max-width:600px; margin-top:20px;">
    </div>
  </section>

  <!-- ====== PRODUCT OVERVIEW ====== -->
  <section class="product-detail" style="padding:60px 0;">
    <div class="container">
      <div class="row">
        <div class="col-md-6">
          <img src="images/large-img-1.jpg" alt="Depth Gauge Device" class="img-responsive">
        </div>
        <div class="col-md-6">
          <h2>Product Overview</h2>
          <p>
            Professional-grade depth gauge engineered for B2B applications requiring accurate cavity and depth measurements. With ±0.05mm accuracy and a range up to 150mm, this instrument is ideal for quality control, manufacturing verification, and precision inspection tasks in industrial settings.
          </p>
          <p style="margin-top:20px;">
            The hardened steel rod and precision base ensure consistent measurements, while the easy-to-read dial display provides clear readings in various lighting conditions. Suitable for measuring holes, slots, steps, and cavities in manufacturing environments.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== KEY FEATURES ====== -->
  <section style="background:#fafafa; padding:60px 0;">
    <div class="container">
      <h2 class="text-center">Key Features & Capabilities</h2>
      <div class="row" style="margin-top:30px;">
        <div class="col-md-12">
          <ul>
            <li>- ±0.05mm accuracy rating</li>
            <li>- 0-150mm (0-6 inch) measurement range</li>
            <li>- Dial indicator display for easy reading</li>
            <li>- Hardened steel rod construction</li>
            <li>- Stable magnetic base for hands-free operation</li>
            <li>- Suitable for holes, slots, steps, and cavities</li>
            <li>- Compact and portable design</li>
            <li>- No battery required - mechanical operation</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== SPECIFICATIONS ====== -->
  <section style="padding:60px 0;">
    <div class="container">
      <h2 class="text-center">Technical Specifications</h2>
      <table class="table table-bordered table-striped" style="margin-top:30px;">
        <thead>
          <tr>
            <th>Parameter</th>
            <th>Value</th>
            <th>Unit</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Measurement Range</td>
            <td>0-150</td>
            <td>mm</td>
          </tr>
          <tr>
            <td>Accuracy</td>
            <td>±0.05</td>
            <td>mm</td>
          </tr>
          <tr>
            <td>Resolution</td>
            <td>0.1</td>
            <td>mm</td>
          </tr>
          <tr>
            <td>Dial Graduations</td>
            <td>0.1 or 0.005 inch</td>
            <td>-</td>
          </tr>
          <tr>
            <td>Base</td>
            <td>Magnetic</td>
            <td>-</td>
          </tr>
          <tr>
            <td>Rod Material</td>
            <td>Hardened Steel</td>
            <td>-</td>
          </tr>
          <tr>
            <td>Weight</td>
            <td>250</td>
            <td>g</td>
          </tr>
          <tr>
            <td>Display Type</td>
            <td>Dial Indicator</td>
            <td>-</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ====== APPLICATIONS ====== -->
  <section style="background:#fafafa; padding:60px 0;">
    <div class="container">
      <h2 class="text-center">Industrial Applications</h2>
      <div class="row" style="margin-top:40px;">
        <div class="col-md-4">
          <h5 style="text-align:center;">Cavity Measurement</h5>
          <p>Precise depth measurement of holes, slots, and cavities in manufactured components. Essential for quality verification on production lines.</p>
        </div>
        <div class="col-md-4">
          <h5 style="text-align:center;">Quality Control</h5>
          <p>Batch sampling and dimensional verification of cavity depths. Ensures compliance with design specifications and ISO standards.</p>
        </div>
        <div class="col-md-4">
          <h5 style="text-align:center;">Manufacturing</h5>
          <p>On-the-floor inspection of machined parts and assemblies. Ideal for CNC machining verification and general manufacturing QA.</p>
        </div>
      </div>
    </div>
  </section>

