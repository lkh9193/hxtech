<style>
/* Fixed header container */
.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  background: #fff;
  z-index: 9999;
  box-shadow: 0 2px 6px rgba(0,0,0,0.08);
  padding: 12px 0; /* vertical padding */
}

/* Push body down so content isn't hidden under header */
body {
  padding-top: 80px; /* adjust depending on header height */
}

/* Flex alignment */
.site-header .container {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Logo */
.site-header .logo img {
  max-height: 50px;
}

/* Navbar links */
